# URL da API consumida pelo app.
# Variáveis EXPO_PUBLIC_* ficam disponíveis no código do app.
#
# O padrão no código já é http://localhost:3333 (funciona no iOS Simulator e na
# Web). Ajuste abaixo conforme onde o app roda:
#
#   - iOS Simulator / Web:      http://localhost:3333
#   - Emulador Android (AVD):   http://10.0.2.2:3333
#   - Celular físico (Expo Go): http://<IP-DA-SUA-MAQUINA>:3333
#                               (ex.: http://192.168.0.10:3333)
EXPO_PUBLIC_API_URL=http://localhost:3333
