# Porta HTTP da API
PORT=3333

# String de conexão do MongoDB
# Para o docker-compose deste repositório:
MONGODB_URI=mongodb://ifsafe:ifsafe@localhost:27017/ifsafe?authSource=admin

# Segredo para assinatura dos tokens JWT (troque por um valor forte)
JWT_SECRET=troque-este-segredo
# Validade do token (ex.: 7d, 24h, 3600)
JWT_EXPIRES_IN=7d
